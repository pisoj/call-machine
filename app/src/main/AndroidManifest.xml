<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />
    <attribution android:tag="incall_music" android:label="@string/app_name" />

    <!-- To record phone call audio -->
    <uses-permission android:name="android.permission.CAPTURE_AUDIO_OUTPUT"
        tools:ignore="ProtectedPermissions" />

    <!-- Do get notified when phone call starts/ends -->
    <uses-permission android:name="android.permission.CONTROL_INCALL_EXPERIENCE"
        tools:ignore="ProtectedPermissions" />

    <!-- To include contact name in file names -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- To upload recordings to WetRadio -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- For starting WetRadio Upload service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"
        tools:ignore="ForegroundServicesPolicy" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CallMachine"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service android:name=".call.InCallService"
            android:permission="android.permission.BIND_INCALL_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.telecom.InCallService"/>
            </intent-filter>
        </service>

        <service android:name=".wetradio.WetRadioUploadService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <provider
            android:name=".files.FileProvider"
            android:authorities="com.zutiradio.callmachine.files.cache"
            android:exported="false"
            android:grantUriPermissions="true" />
    </application>

</manifest>